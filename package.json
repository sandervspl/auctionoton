{
  "name": "auctionoton",
  "version": "2.1.3",
  "description": "",
  "main": "index.js",
  "scripts": {
    "lint": "eslint ./src --ext .ts,.tsx",
    "build": "NODE_ENV=production webpack -c webpack.config.js",
    "dev": "nodemon",
    "postbuild": "cd dist; zip -D -r ../auctionoton-$npm_package_version.zip ./*; zip -d ../auctionoton-$npm_package_version.zip *.DS_Store",
    "preinstall": "npx npm-force-resolutions",
    "preversion": "npm run lint",
    "version": "npx json -I -f src/manifest.json -e \"this.version='$npm_package_version'\"; git add .",
    "postversion": "git push; git push --tags",
    "mozilla": "zip -r auctionoton-$npm_package_version-source.zip ./src config.js defines.d.ts global.d.ts package.json package-lock.json README.md tsconfig.json webpack.config.js"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "immer": "7.0.7",
    "lodash": "4.17.19",
    "react": "16.13.1",
    "react-dom": "16.13.1",
    "recoil": "0.0.10"
  },
  "devDependencies": {
    "@svgr/webpack": "5.4.0",
    "@types/chrome": "0.0.113",
    "@types/firefox-webext-browser": "70.0.1",
    "@types/lodash": "4.14.159",
    "@types/react": "16.9.44",
    "@types/react-dom": "16.9.8",
    "@typescript-eslint/eslint-plugin": "2.33.0",
    "@typescript-eslint/parser": "2.33.0",
    "copy-webpack-plugin": "6.0.2",
    "eslint": "7.6.0",
    "eslint-config-react-app": "5.2.1",
    "eslint-plugin-flowtype": "5.2.0",
    "eslint-plugin-import": "2.22.0",
    "eslint-plugin-jsx-a11y": "6.3.1",
    "eslint-plugin-react": "7.20.5",
    "eslint-plugin-react-hooks": "4.0.8",
    "imports-loader": "0.8.0",
    "minimist": "1.2.5",
    "nodemon": "2.0.4",
    "rimraf": "3.0.2",
    "svg-inline-loader": "0.8.2",
    "ts-loader": "7.0.5",
    "tsconfig-paths-webpack-plugin": "3.3.0",
    "typescript": "3.9.7",
    "webpack": "4.43.0",
    "webpack-cli": "3.3.11",
    "webpack-notifier": "1.8.0"
  },
  "resolutions": {
    "minimist": "^1.2.5"
  }
}
