{
  "manifest_version": 2,
  "name": "Auctionoton",
  "version": "1.0.8",
  "description": "Display current Auction House price data for items on classic.wowhead.com",
  "content_scripts": [
    {
      "matches": [
        "https://classic.wowhead.com/item=*"
      ],
      "js": [
        "index.js"
      ]
    }
  ],
  "web_accessible_resources": [
    "index.js"
  ],
  "background": {
    "scripts": [
      "background.js"
    ],
    "persistent": false
  },
  "browser_action": {
    "default_icon": "static/icon.png",
    "default_popup": "form.html",
    "default_title": "Auctionoton — Auction House Data for Wowhead"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "auctiono@ton.com"
    }
  },
  "icons": {
    "16": "static/icon-16.png",
    "32": "static/icon-32.png",
    "48": "static/icon-48.png",
    "128": "static/icon-128.png"
  },
  "permissions": [
    "storage",
    "<all_urls>"
  ]
}
