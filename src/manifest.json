{
  "name": "Wowhead Auction House Price Data",
  "description": "Display current Auction House price data for items on classic.wowhead.com",
  "content_scripts": [{
      "matches": [
        "https://classic.wowhead.com/item=*"
      ],
      "js": [
        "index.ts"
      ]
  }],
  "web_accessible_resources": [
    "index.ts"
  ],
  "background": {
    "scripts": [
      "background.ts"
    ],
    "persistent": false
  }
}
