{
  "name": "auctionoton",
  "version": "1.0.7",
  "description": "",
  "main": "index.js",
  "scripts": {
    "lint": "eslint ./src --ext .ts,.tsx",
    "build": "NODE_ENV=production webpack -c webpack.config.js",
    "postbuild": "cd dist; zip -D -r ../auctionoton-$npm_package_version.zip ./*; zip -d ../auctionoton-$npm_package_version.zip *.DS_Store",
    "preinstall": "npx npm-force-resolutions",
    "preversion": "npm run lint",
    "version": "npx json -I -f src/manifest.json -e \"this.version='$npm_package_version'\"",
    "postversion": "git push && git push --tags"
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/chrome": "0.0.113",
    "@typescript-eslint/eslint-plugin": "2.33.0",
    "@typescript-eslint/parser": "2.33.0",
    "copy-webpack-plugin": "6.0.2",
    "eslint": "7.0.0",
    "minimist": "1.2.5",
    "rimraf": "3.0.2",
    "svg-inline-loader": "0.8.2",
    "ts-loader": "7.0.5",
    "typescript": "3.9.2",
    "webpack": "4.43.0",
    "webpack-cli": "3.3.11"
  },
  "resolutions": {
    "minimist": "^1.2.5"
  }
}
