{
  "name": "auctionoton",
  "version": "2.3.1",
  "description": "",
  "main": "index.js",
  "scripts": {
    "lint": "eslint ./src --ext .ts,.tsx",
    "build": "NODE_ENV=production webpack -c webpack.config.js",
    "dev": "nodemon",
    "postbuild": "cd dist; zip -D -r ../auctionoton-$npm_package_version.zip ./*; zip -d ../auctionoton-$npm_package_version.zip *.DS_Store",
    "preversion": "tsc --noEmit && npm run lint",
    "version": "npx json -I -f src/manifest.json -e \"this.version='$npm_package_version'\"; git add .",
    "postversion": "git push && git push --tags && npm run build && npm run mozilla",
    "mozilla": "zip -r auctionoton-$npm_package_version-source.zip ./src config.js defines.d.ts global.d.ts package.json package-lock.json README.md tsconfig.json webpack.config.js",
    "tc": "tsc --noEmit"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "dayjs": "1.10.5",
    "immer": "9.0.2",
    "lodash": "4.17.21",
    "react": "17.0.2",
    "react-dom": "17.0.2",
    "w3c-keys": "1.0.3",
    "zustand": "3.5.1"
  },
  "devDependencies": {
    "@svgr/webpack": "5.5.0",
    "@types/chrome": "0.0.143",
    "@types/firefox-webext-browser": "82.0.0",
    "@types/lodash": "4.14.170",
    "@types/react": "17.0.8",
    "@types/react-dom": "17.0.5",
    "@typescript-eslint/eslint-plugin": "4.25.0",
    "@typescript-eslint/parser": "4.25.0",
    "copy-webpack-plugin": "9.0.0",
    "eslint": "7.27.0",
    "eslint-config-react-app": "6.0.0",
    "eslint-plugin-flowtype": "5.7.2",
    "eslint-plugin-import": "2.23.4",
    "eslint-plugin-jsx-a11y": "6.4.1",
    "eslint-plugin-react": "7.24.0",
    "eslint-plugin-react-hooks": "4.2.0",
    "nodemon": "2.0.7",
    "rimraf": "3.0.2",
    "svg-inline-loader": "0.8.2",
    "ts-loader": "9.2.2",
    "tsconfig-paths-webpack-plugin": "3.5.1",
    "typescript": "4.3.2",
    "webpack": "5.38.1",
    "webpack-cli": "4.7.0",
    "webpack-notifier": "1.13.0"
  }
}
